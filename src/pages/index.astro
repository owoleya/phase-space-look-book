---
import "../styles/main.css";
import BgTracker from "../components/bg-tracker.astro";
import FriendsTracker from "../components/friends-tracker.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon/favicon-16x16.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicon/apple-touch-icon.png"
    />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      window.waitForImages = async () => {
        const getImagesFromAttr = (id, attr) => {
          const el = document.getElementById(id);
          if (!el || !el.dataset[attr]) return [];
          try {
            const data = JSON.parse(el.dataset[attr]);
            return Array.isArray(data) ? data.flat(Infinity) : [];
          } catch (e) {
            return [];
          }
        };

        const allSrcs = new Set([
          ...Array.from(document.querySelectorAll("img")).map((img) => img.src),
          ...getImagesFromAttr("bg-tracker-data", "images"),
          ...getImagesFromAttr("friends-tracker-data", "galleries"),
        ]);

        const load = (src) =>
          new Promise((resolve) => {
            if (!src) return resolve();
            const img = new Image();
            img.onload = img.onerror = resolve;
            img.src = src;
          });

        await Promise.all(Array.from(allSrcs).map(load));
      };

      // Wait for everything and then signal Alpine
      window.addEventListener("load", async () => {
        await window.waitForImages();
        document.dispatchEvent(new CustomEvent("images-ready"));
      });
    </script>
    <script src="//unpkg.com/alpinejs" defer></script>
    <title>Phase Space Look Book!!!!!!!</title>
    <style>
      [x-cloak] {
        display: none !important;
      }
    </style>
  </head>
  <body
    x-data="{ 
    isLoaded: false,
    view: 'friends',
    filterModal:false,
    filters:{
      hue:0,
      dilate:0.01,
      wavy:0,
      red:1,
      blue:1,
      green:1
    }
  }"
    @images-ready.window="isLoaded = true"
  >
    <div
      x-show="filterModal && isLoaded"
      class="fixed inset-0 z-[100] flex items-center justify-center"
      @click="filterModal = false"
      x-cloak
    >
      <div
        class="border border-phasegreen p-8 rounded-3xl w-full max-w-sm flex flex-col gap-6 text-phasegreen shadow-2xl bg-black"
        @click.stop
      >
        <div class="flex justify-between items-center">
          <h2 class="font-bold text-xl uppercase tracking-widest">Filters</h2>
          <button
            @click="filterModal = false"
            class="hover:text-white transition-colors"
          >
            <svg
              class="size-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        <div class="flex flex-col gap-4">
          <label
            class="flex flex-col gap-2 text-xs font-bold tracking-widest uppercase"
          >
            <div class="flex justify-between">
              <span>Hue</span><span
                x-text="filters.hue + '°'"
                class="text-white"></span>
            </div>
            <input
              type="range"
              min="0"
              max="360"
              x-model.number="filters.hue"
              class="accent-phasegreen"
            />
          </label>
          <label
            class="flex flex-col gap-2 text-xs font-bold tracking-widest uppercase"
          >
            <div class="flex justify-between">
              <span>Dilate</span><span
                x-text="filters.dilate"
                class="text-white"></span>
            </div>
            <input
              type="range"
              min="0"
              max="20"
              x-model.number="filters.dilate"
              class="accent-phasegreen"
            />
          </label>
          <label
            class="flex flex-col gap-2 text-xs font-bold tracking-widest uppercase"
          >
            <div class="flex justify-between">
              <span>Wavy</span><span x-text="filters.wavy" class="text-white"
              ></span>
            </div>
            <input
              type="range"
              min="0"
              max="100"
              x-model.number="filters.wavy"
              class="accent-phasegreen"
            />
          </label>
          <label
            class="flex flex-col gap-2 text-xs font-bold tracking-widest uppercase"
          >
            <div class="flex justify-between">
              <span>Red</span><span x-text="filters.red" class="text-white"
              ></span>
            </div>
            <input
              type="range"
              min="0"
              max="5"
              step="0.1"
              x-model.number="filters.red"
              class="accent-phasegreen"
            />
          </label>
          <label
            class="flex flex-col gap-2 text-xs font-bold tracking-widest uppercase"
          >
            <div class="flex justify-between">
              <span>Green</span><span x-text="filters.green" class="text-white"
              ></span>
            </div>
            <input
              type="range"
              min="0"
              max="5"
              step="0.1"
              x-model.number="filters.green"
              class="accent-phasegreen"
            />
          </label>
          <label
            class="flex flex-col gap-2 text-xs font-bold tracking-widest uppercase"
          >
            <div class="flex justify-between">
              <span>Blue</span><span x-text="filters.blue" class="text-white"
              ></span>
            </div>
            <input
              type="range"
              min="0"
              max="5"
              step="0.1"
              x-model.number="filters.blue"
              class="accent-phasegreen"
            />
          </label>
        </div>
      </div>
    </div>

    <div
      x-show="isLoaded"
      class="fixed h-8 flex gap-4 left-1/2 whitespace-nowrap -translate-x-1/2 bottom-6 z-50"
      x-cloak
    >
      <div class="flex h-full bg-phasegreen rounded-full">
        <button
          @click="view = 'friends'"
          :class="view === 'friends' ? 'bg-black text-phasegreen' : 'text-black hover:text-black/20 '"
          class="px-6 py-2 rounded-full text-xs uppercase tracking-widest font-bold cursor-pointer"
        >
          FRIENDSSS
        </button>
        <button
          @click="view = 'bg'"
          :class="view === 'bg' ? 'bg-black text-phasegreen' : 'text-black hover:text-black/20 '"
          class="px-6 py-2 rounded-full text-xs uppercase tracking-widest font-bold cursor-pointer"
        >
          LOUIS NAKED
        </button>
      </div>
      <button
        @click="filterModal = true"
        class="bg-phasegreen hover:text-phasegreen hover:bg-black text-black size-8 flex items-center justify-center rounded-full"
      >
        <svg
          class="size-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="m14.622 17.897-10.68-2.913"></path><path
            d="M18.376 2.622a1 1 0 1 1 3.002 3.002L17.36 9.643a.5.5 0 0 0 0 .707l.944.944a2.41 2.41 0 0 1 0 3.408l-.944.944a.5.5 0 0 1-.707 0L8.354 7.348a.5.5 0 0 1 0-.707l.944-.944a2.41 2.41 0 0 1 3.408 0l.944.944a.5.5 0 0 0 .707 0z"
          ></path><path
            d="M9 8c-1.804 2.71-3.97 3.46-6.583 3.948a.507.507 0 0 0-.302.819l7.32 8.883a1 1 0 0 0 1.185.204C12.735 20.405 16 16.792 16 15"
          ></path></svg
        >
      </button>
    </div>

    <div
      x-show="isLoaded"
      class="relative"
      style="transform: translateZ(0);"
      :style="isLoaded ? `filter: url(#combined-filter);` : ''"
      x-cloak
    >
      <div x-show="view === 'bg'" x-cloak>
        <BgTracker />
      </div>
      <div x-show="view === 'friends'" x-cloak>
        <FriendsTracker />
      </div>
    </div>

    <svg
      style="position: absolute; width: 0; height: 0; pointer-events: none; overflow: hidden;"
      aria-hidden="true"
    >
      <defs>
        <filter id="combined-filter">
          <!-- 1. Hue Rotate -->
          <feColorMatrix
            type="hueRotate"
            :values="filters.hue"
            result="HUE_ROTATE"></feColorMatrix>

          <!-- 2. Dilate (Blur/Expand) -->
          <feMorphology
            in="HUE_ROTATE"
            operator="dilate"
            :radius="filters.dilate"
            result="MORPHOLOGY"></feMorphology>

          <!-- 3. Wavy (Displacement) -->
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.01 0.02"
            numOctaves="1"
            result="NOISE"
          >
            <animate
              attributeName="baseFrequency"
              dur="10s"
              keyTimes="0;0.5;1"
              values="0.01 0.02;0.02 0.04;0.01 0.02"
              repeatCount="indefinite"></animate>
          </feTurbulence>
          <feDisplacementMap
            in="MORPHOLOGY"
            in2="NOISE"
            xChannelSelector="R"
            yChannelSelector="G"
            :scale="filters.wavy"
            result="DISPLACEMENT"></feDisplacementMap>

          <!-- 4. Color Matrix (RGB Scaling) -->
          <feColorMatrix
            in="DISPLACEMENT            type="
            matrix"
            :values="`${filters.red} 0 0 0 0 0 ${filters.green} 0 0 0 0 0 ${filters.blue} 0 0 0 0 0 1 0`"
          >
          </feColorMatrix>
        </filter>
      </defs>
    </svg>

    <h1
      x-show="isLoaded"
      class="text-4xl fixed top-4 left-1/2 whitespace-nowrap -translate-x-1/2 z-50 font-black tracking-tighter text-white uppercase"
      x-cloak
    >
      Phase Space!!!!!!
    </h1>
  </body>
</html>
