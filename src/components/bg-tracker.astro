  id="frame-label"
  style="left: 50%"
  class="fixed bottom-24 h-8 w-32 flex items-center gap-2 justify-center bg-green-800/20 rounded-xl z-20 pointer-events-auto cursor-pointer transform max-@3xl:left-1/2 -translate-x-1/2 transition-colors hover:bg-green-800/40 backdrop-blur-md text-white font-medium shadow-lg"
>
  Look 1
</div> -->

<script>
  import { gsap } from "gsap";
  import { Draggable } from "gsap/Draggable";

  gsap.registerPlugin(Draggable);

  console.log(Draggable);

  const bgFrame = document.getElementById("bg-frame");
  const bgWrapper = document.getElementById("bg-wrapper");
  const bgImage = document.getElementById("bg-image");
  const cursorLabel = document.getElementById("frame-label");
  const dataEl = document.getElementById("bg-tracker-data");

  const optimizedImages = dataEl
    ? JSON.parse(dataEl.dataset.images || "[]")
    : [];
  const margin = 16;
  const totalFrames = optimizedImages.length || 13;

  // --- 1. Swap Frames & Badge Label ---
  const updateLook = (pointerX: number, isMobile: boolean) => {
    if (!bgFrame || bgFrame.offsetParent === null) return;
    const screenWidth = window.innerWidth;
    // console.log("updateLook", { pointerX, isMobile, screenWidth });

    // Calculate which of the 14 columns the pointer is in
    let colIndex = Math.floor((pointerX / screenWidth) * totalFrames);
    if (colIndex < 0) colIndex = 0;
    if (colIndex >= totalFrames) colIndex = totalFrames - 1;

    const frameNum = colIndex + 1;

    // Update image source using the optimized URLs array
    if (bgImage && optimizedImages.length > 0) {
      const newSrc = optimizedImages[colIndex];
      // Only update if source has changed
      if (
        bgImage.getAttribute("src") !== newSrc &&
        (bgImage as HTMLImageElement).src !== newSrc
      ) {
        bgImage.setAttribute("src", newSrc);
      }
    }

    // Update label position and text
    if (cursorLabel) {
      cursorLabel.textContent = `Look ${frameNum}`;

      // Only track X position if we are not on mobile
      if (!isMobile) {
        const maxLeft = screenWidth - cursorLabel.offsetWidth / 2 - margin;
        const clampedX = Math.max(
          0 + cursorLabel.offsetWidth / 2 + margin,
          Math.min(pointerX, maxLeft),
        );
        cursorLabel.style.left = `${clampedX}px`;
      } else {
        // Reset left inline style so Tailwind max-@3xl overrides apply correctly
        cursorLabel.style.left = "50%";
      }
    }
  };

  // --- 2. Interaction Logic Desktop ---
  let rafScheduled = false;
  let isMobileView = window.matchMedia("(max-width: 768px)").matches;

  const handleMouseMove = (e: MouseEvent) => {
    if (
      isMobileView ||
      rafScheduled ||
      !bgFrame ||
      bgFrame.offsetParent === null
    )
      return;
    rafScheduled = true;
    requestAnimationFrame(() => {
      updateLook(e.clientX, false);
      rafScheduled = false;
    });
  };

  // Set up GSAP Draggable for mobile
  let draggableInstance: Draggable[] = [];

  function initDraggable() {
    if (!bgImage || !bgWrapper || !bgFrame) return;

    // Kill existing instance on re-init (e.g. resize)
    if (draggableInstance.length) {
      draggableInstance[0].kill();
    }

    const containerWidth = bgFrame.offsetWidth;
    const imageWidth = (bgImage as HTMLImageElement).offsetWidth;
    const minX = Math.min(0, containerWidth - imageWidth);

    draggableInstance = Draggable.create(bgWrapper, {
      type: "x",
      //   inertia: true,
      bounds: {
        minX: minX,
        maxX: 0,
        minY: 0,
        maxY: 0,
      },
      //   edgeResistance: 0.85,
      onDrag: function () {
        // Map drag position to a 0..screenWidth range for frame lookup
        const progress = minX === 0 ? 0 : this.x / minX; // 0 at maxX, 1 at minX
        const pointerX = progress * window.innerWidth;
        updateLook(pointerX, true);
      },
    });
  }

  // Wait for image to load so dimensions are known
  if (bgImage) {
    if ((bgImage as HTMLImageElement).complete) {
      initDraggable();
    } else {
      bgImage.addEventListener("load", initDraggable);
    }
    window.addEventListener("resize", initDraggable);
  }

  // Toggle behavior based on screen size
  const mql = window.matchMedia("(max-width: 768px)");
  const handleResize = (e: MediaQueryListEvent | MediaQueryList) => {
    isMobileView = e.matches;

    // Reset view states depending on transition
    if (isMobileView) {
      window.removeEventListener("mousemove", handleMouseMove);
      if (draggableInstance[0]) draggableInstance[0].enable();
    } else {
      window.addEventListener("mousemove", handleMouseMove);
      if (draggableInstance[0]) draggableInstance[0].disable();
    }
  };

  // Init
  mql.addEventListener("change", handleResize);
  handleResize(mql);
</script>
