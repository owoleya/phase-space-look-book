---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";

const frames = await getCollection("frames");

const sortedFrames = frames.sort((a, b) => {
  const numA = parseInt(a.id.match(/frame(\d+)$/)?.[1] || "0", 10);
  const numB = parseInt(b.id.match(/frame(\d+)$/)?.[1] || "0", 10);
  return numA - numB;
});

const framesData = await Promise.all(
  sortedFrames.map(async (frame: any) => {
    const optimizedMain = await getImage({
      src: frame.data.frame,
      format: "webp",
    });
    return {
      main: optimizedMain.src,
    };
  }),
);
const optimizedImages = framesData.map((f: any) => f.main);
---

{
  optimizedImages.map((src, index) => (
    <link
      rel="preload"
      as="image"
      href={src}
      fetchpriority={index < 2 ? "high" : "low"}
    />
  ))
}
<div
  id="bg-tracker-data"
  data-images={JSON.stringify(optimizedImages)}
  class="hidden"
>
</div>

<div class="w-full h-svh flex relative z-0">
  <div id="bg-frame" class="h-svh lg:h-full w-full relative overflow-hidden">
    <div id="bg-wrapper" class="absolute h-full">
      <img
        id="bg-image"
        class="w-auto max-w-none min-w-full h-svh object-cover lg:w-screen lg:max-w-full lg:min-w-0 lg:h-screen"
        src={optimizedImages[0]}
      />
    </div>
  </div>
</div>

