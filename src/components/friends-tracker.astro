---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import background from "../assets/phasegang/background.webp";

const friends = await getCollection("friends");

const sortedFriends = friends.sort((a, b) => {
  const numA = parseInt(a.id.match(/frame(\d+)$/)?.[1] || "0", 10);
  const numB = parseInt(b.id.match(/frame(\d+)$/)?.[1] || "0", 10);
  return numA - numB;
});
---

<div
  id="friends-preload-container"
  aria-hidden="true"
  style="position: absolute; width: 0; height: 0; overflow: hidden; z-index: -1;"
>
  {
    sortedFriends.map((friend, colIndex) => {
      const gallerySrcs =
        friend.data.gallery && friend.data.gallery.length > 0
          ? friend.data.gallery
          : [friend.data.frame];

      return gallerySrcs.map((src: any, imgIndex: number) => (
        <Image
          src={src}
          alt={`Friend ${colIndex + 1} Image ${imgIndex + 1}`}
          format="webp"
          data-col={colIndex}
          data-img={imgIndex}
          fetchpriority={colIndex < 2 && imgIndex === 0 ? "high" : "low"}
          loading={colIndex < 2 && imgIndex === 0 ? "eager" : "lazy"}
        />
      ));
    })
  }
</div>

<div class="w-full h-svh flex relative z-0">
  <div
    id="friends-bg-frame"
    class="h-full w-full relative overflow-hidden z-10"
  >
    <div id="friends-bg-wrapper" class="absolute h-full">
      <Image
        id="friends-bg-image"
        class="lg:w-screen min-w-fit lg:min-w-auto h-screen object-cover relative z-10"
        src={
          sortedFriends[0].data.gallery && sortedFriends[0].data.gallery.length > 0
            ? sortedFriends[0].data.gallery[0]
            : sortedFriends[0].data.frame
        }
        alt="Main Friend Look"
        format="webp"
        fetchpriority="high"
        loading="eager"
      />
      <Image
        class="lg:w-screen min-w-fit lg:min-w-auto h-screen object-cover absolute inset-0"
        src={background}
        alt="Background"
        format="webp"
      />
    </div>
  </div>
</div>

