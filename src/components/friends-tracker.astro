---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import background from "../assets/phasegang/background.png";

const friends = await getCollection("friends");

const sortedFriends = friends.sort((a, b) => {
  const numA = parseInt(a.id.match(/frame(\d+)$/)?.[1] || "0", 10);
  const numB = parseInt(b.id.match(/frame(\d+)$/)?.[1] || "0", 10);
  return numA - numB;
});

const friendsData = await Promise.all(
  sortedFriends.map(async (friend: any) => {
    // Determine the images to use: gallery if present and not empty, otherwise fallback to frame
    const gallerySrcs =
      friend.data.gallery && friend.data.gallery.length > 0
        ? friend.data.gallery
        : [friend.data.frame];

    const optimizedGallery = await Promise.all(
      gallerySrcs.map(async (src: any) => {
        const optimizedImage = await getImage({ src, format: "webp" });
        return optimizedImage.src;
      }),
    );

    return {
      gallery: optimizedGallery,
    };
  }),
);

// Map to an array of arrays of optimized image srcs
const optimizedGalleries = friendsData.map((f: any) => f.gallery);
---

{
  optimizedGalleries.map((gallery: string[], colIndex: number) =>
    gallery.map((src: string, imgIndex: number) => (
      <link
        rel="preload"
        as="image"
        href={src}
        fetchpriority={colIndex < 2 && imgIndex === 0 ? "high" : "low"}
      />
    )),
  )
}
<div
  id="friends-tracker-data"
  data-galleries={JSON.stringify(optimizedGalleries)}
  class="hidden"
>
</div>

<div class="w-full h-svh flex relative z-0">
  <div
    id="friends-bg-frame"
    class="h-svh lg:h-full w-full relative overflow-hidden z-10"
  >
    <div id="friends-bg-wrapper" class="absolute h-svh lg:h-full">
      <img
        id="friends-bg-image"
        class="w-auto max-w-none min-w-full h-svh object-cover lg:w-screen lg:max-w-full lg:min-w-0 lg:h-screen relative z-10"
        src={optimizedGalleries[0]?.[0]}
      />
      <img
        class="w-auto max-w-none min-w-full h-svh object-cover lg:w-screen lg:max-w-full lg:min-w-0 lg:h-screen absolute inset-0"
        src={background.src}
      />
    </div>
  </div>
</div>

